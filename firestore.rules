rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Profiles ───────────────────────────────────────────────────────────────
    // Users can only read/write their own profile
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Collection Group Queries (Search) ──────────────────────────────────────
    match /{path=**}/services/{serviceId} {
      allow read: if true;
    }
    
    match /{path=**}/stylists/{stylistId} {
      allow read: if true;
    }

    // ─── Businesses ─────────────────────────────────────────────────────────────
    // Public read; only owner can write
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if request.auth != null
                             && resource.data.owner_id == request.auth.uid;

      // Specific rules for stylists to allow self-linking during invitation
      match /stylists/{stylistId} {
        allow read: if true;
        allow update: if request.auth != null && (
          // 1. Business owner can update any field
          get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid ||
          // 2. Stylist can ONLY update their own 'userId' field to link their account
          (request.auth.token.email.lower() == resource.data.email.lower() && 
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId']))
        );
        allow create, delete: if request.auth != null && 
          get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid;
      }

      // Other Subcollections: hours, services, portfolio
      match /hours/{docId} { allow read: if true; allow write: if request.auth != null && get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid; }
      match /services/{docId} { allow read: if true; allow write: if request.auth != null && get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid; }
      match /portfolio/{docId} { allow read: if true; allow write: if request.auth != null && get(/databases/$(database)/documents/businesses/$(businessId)).data.owner_id == request.auth.uid; }
    }

    // ─── Bookings ───────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Public read is required for customers to calculate open availability slots
      allow read: if true;
      
      // Customers can only create bookings for themselves
      allow create: if request.auth != null 
                    && request.resource.data.customer_id == request.auth.uid;
                    
      // Only the customer or the business owner can edit/cancel the booking
      allow update, delete: if request.auth != null && (
        resource.data.customer_id == request.auth.uid || 
        get(/databases/$(database)/documents/businesses/$(resource.data.business_id)).data.owner_id == request.auth.uid
      );
    }
  }
}
